      <colspec colname='c2'/>
      <colspec colname='c3'/>
<thead>
      <row  class='markdownTableHead'>
<entry>
<para>Paramètre  </para>
</entry><entry>
<para>Type  </para>
</entry><entry>
<para>Description  </para>
</entry></row>
</thead><tbody>
      <row  class='markdownTableRowOdd'>
<entry>
<para>-  </para>
</entry><entry>
<para>-  </para>
</entry><entry>
<para>(aucun)  </para>
</entry></row>
    </tbody>
    </tgroup>
</informaltable>
</para>

<para><emphasis role="bold">Effet</emphasis> :<itemizedlist>
<listitem>
<para>Vide complètement le buffer <computeroutput><link linkend="_com__utils_8h_1af553c31425b32bd9c020380c942ed3bd">TxData</link>[8]</computeroutput></para>
</listitem><listitem>
