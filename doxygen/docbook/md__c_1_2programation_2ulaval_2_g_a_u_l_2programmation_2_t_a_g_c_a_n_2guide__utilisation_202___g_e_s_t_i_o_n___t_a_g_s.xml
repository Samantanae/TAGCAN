<section xml:id="_md__c_1_2programation_2ulaval_2_g_a_u_l_2programmation_2_t_a_g_c_a_n_2guide__utilisation_202___g_e_s_t_i_o_n___t_a_g_s_1autotoc_md49">
<title>Valeur de retour</title>
<para><itemizedlist>
<listitem>
<para><emphasis role="bold">CAN_TG_SUCCESS</emphasis> (0) - Succès</para>
</listitem><listitem>
<para><emphasis role="bold">CAN_TG_ERROR_VALUE_TO_BIG</emphasis> - La valeur dépasse les <computeroutput>n_bit</computeroutput> bits du tag</para>
</listitem><listitem>
<para>Autres codes d&apos;erreur - Tag non trouvé, etc.</para>
</listitem></itemizedlist>
</para>
</section>
<section xml:id="_md__c_1_2programation_2ulaval_2_g_a_u_l_2programmation_2_t_a_g_c_a_n_2guide__utilisation_202___g_e_s_t_i_o_n___t_a_g_s_1autotoc_md50">
<title>Comportement important</title>
<para><emphasis role="bold">La valeur est tronquée si elle dépasse la capacité du tag.</emphasis></para>

<para>Par exemple : <literallayout><computeroutput>set_tag(&quot;SEQ&quot;,&#32;3);&#32;&#32;&#32;&#32;&#32;&#32;//&#32;3&#32;bits&#32;-&gt;&#32;plage&#32;0&#32;à&#32;7
set_value(&quot;SEQ&quot;,&#32;10);&#32;&#32;&#32;//&#32;&#32;Erreur&#32;:&#32;10&#32;&gt;&#32;2^3&#32;-&#32;1&#32;=&#32;7
set_value(&quot;SEQ&quot;,&#32;5);&#32;&#32;&#32;&#32;//&#32;&#32;Ok&#32;:&#32;écrit&#32;0b101
</computeroutput></literallayout></para>
</section>
<section xml:id="_md__c_1_2programation_2ulaval_2_g_a_u_l_2programmation_2_t_a_g_c_a_n_2guide__utilisation_202___g_e_s_t_i_o_n___t_a_g_s_1autotoc_md51">
<title>Exemples d&apos;utilisation</title>
<para><literallayout><computeroutput>//&#32;Dans&#32;la&#32;boucle&#32;principale&#32;ou&#32;handler
static&#32;int&#32;seq_counter&#32;=&#32;0;

void&#32;update_telemetry(void)&#32;{
&#32;&#32;&#32;&#32;//&#32;Incrémenter&#32;et&#32;envoyer&#32;le&#32;numéro&#32;de&#32;séquence
&#32;&#32;&#32;&#32;seq_counter&#32;=&#32;(seq_counter&#32;+&#32;1)&#32;%&#32;8;&#32;&#32;//&#32;Cycle&#32;avec&#32;3&#32;bits&#32;(0-7)
&#32;&#32;&#32;&#32;if(set_value(&quot;SEQ&quot;,&#32;seq_counter)&#32;!=&#32;CAN_TG_SUCCESS)&#32;{
&#32;&#32;&#32;&#32;&#32;&#32;&#32;&#32;//&#32;Erreur...
&#32;&#32;&#32;&#32;}

&#32;&#32;&#32;&#32;//&#32;Envoyer&#32;le&#32;statut&#32;batterie
&#32;&#32;&#32;&#32;uint8_t&#32;battery_percent&#32;=&#32;read_battery();&#32;&#32;//&#32;0-100
&#32;&#32;&#32;&#32;if(set_value(&quot;AB&quot;,&#32;battery_percent)&#32;!=&#32;CAN_TG_SUCCESS)&#32;{
&#32;&#32;&#32;&#32;&#32;&#32;&#32;&#32;//&#32;Erreur...
&#32;&#32;&#32;&#32;}

&#32;&#32;&#32;&#32;//&#32;Envoyer&#32;une&#32;pression
&#32;&#32;&#32;&#32;uint16_t&#32;pressure&#32;=&#32;read_sensor();&#32;&#32;//&#32;0-65535
&#32;&#32;&#32;&#32;if(set_value(&quot;N2OPS&quot;,&#32;pressure)&#32;!=&#32;CAN_TG_SUCCESS)&#32;{
&#32;&#32;&#32;&#32;&#32;&#32;&#32;&#32;//&#32;Erreur...
&#32;&#32;&#32;&#32;}

&#32;&#32;&#32;&#32;//&#32;Envoyer&#32;le&#32;timestamp
&#32;&#32;&#32;&#32;uint16_t&#32;time_ms&#32;=&#32;get_timestamp();
&#32;&#32;&#32;&#32;set_value(&quot;TIME&quot;,&#32;time_ms);
}
</computeroutput></literallayout></para>

<para><informaltable frame='bottom'><tgroup cols='1'><colspec align='center'/><tbody><row><entry align='center'>
</entry></row></tbody></tgroup></informaltable>
</para>
</section>
</section>
<section xml:id="_md__c_1_2programation_2ulaval_2_g_a_u_l_2programmation_2_t_a_g_c_a_n_2guide__utilisation_202___g_e_s_t_i_o_n___t_a_g_s_1autotoc_md53">
