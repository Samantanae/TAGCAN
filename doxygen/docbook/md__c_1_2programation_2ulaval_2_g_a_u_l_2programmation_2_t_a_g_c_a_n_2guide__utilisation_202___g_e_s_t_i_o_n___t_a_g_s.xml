<section xml:id="_md__c_1_2programation_2ulaval_2_g_a_u_l_2programmation_2_t_a_g_c_a_n_2guide__utilisation_202___g_e_s_t_i_o_n___t_a_g_s_1autotoc_md43">
<title>Valeur de retour</title>
<para>Consulter <computeroutput><link linkend="__a_p_i___r_e_f_e_r_e_n_c_e_8md">documentation/API_REFERENCE.md</link></computeroutput> pour les codes d&apos;erreur.</para>
</section>
<section xml:id="_md__c_1_2programation_2ulaval_2_g_a_u_l_2programmation_2_t_a_g_c_a_n_2guide__utilisation_202___g_e_s_t_i_o_n___t_a_g_s_1autotoc_md44">
<title>Exemples</title>
<para><literallayout><computeroutput>//&#32;Initialisation&#32;des&#32;tags&#32;(dans&#32;CAN_setup_TAG())
void&#32;CAN_setup_TAG(void)&#32;{
&#32;&#32;&#32;&#32;set_tag(&quot;SEQ&quot;,&#32;3);&#32;&#32;&#32;&#32;&#32;&#32;&#32;&#32;//&#32;3&#32;bits&#32;pour&#32;numéro&#32;séquence
&#32;&#32;&#32;&#32;set_tag(&quot;HB&quot;,&#32;1);&#32;&#32;&#32;&#32;&#32;&#32;&#32;&#32;&#32;//&#32;1&#32;bit&#32;pour&#32;watchdog
&#32;&#32;&#32;&#32;set_tag(&quot;CI&quot;,&#32;2);&#32;&#32;&#32;&#32;&#32;&#32;&#32;&#32;&#32;//&#32;2&#32;bits&#32;pour&#32;continuité
&#32;&#32;&#32;&#32;set_tag(&quot;AB&quot;,&#32;7);&#32;&#32;&#32;&#32;&#32;&#32;&#32;&#32;&#32;//&#32;7&#32;bits&#32;pour&#32;batterie&#32;(0-100%)
&#32;&#32;&#32;&#32;set_tag(&quot;N2OPS&quot;,&#32;16);&#32;&#32;&#32;&#32;&#32;//&#32;16&#32;bits&#32;pour&#32;pression&#32;(0-65535&#32;Pa)
&#32;&#32;&#32;&#32;set_tag(&quot;TIME&quot;,&#32;16);&#32;&#32;&#32;&#32;&#32;&#32;//&#32;16&#32;bits&#32;pour&#32;timestamp&#32;(0-65535&#32;ms)
}
</computeroutput></literallayout></para>

<para><informaltable frame='bottom'><tgroup cols='1'><colspec align='center'/><tbody><row><entry align='center'>
</entry></row></tbody></tgroup></informaltable>
</para>
</section>
</section>
<section xml:id="_md__c_1_2programation_2ulaval_2_g_a_u_l_2programmation_2_t_a_g_c_a_n_2guide__utilisation_202___g_e_s_t_i_o_n___t_a_g_s_1autotoc_md46">
