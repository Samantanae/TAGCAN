.TH "md__c_1_2programation_2ulaval_2_g_a_u_l_2programmation_2_t_a_g_c_a_n_2guide__utilisation_202___g_e_s_t_i_o_n___t_a_g_s" 3 "TAGCAN" \" -*- nroff -*-
.ad l
.nh
.SH NAME
md__c_1_2programation_2ulaval_2_g_a_u_l_2programmation_2_t_a_g_c_a_n_2guide__utilisation_202___g_e_s_t_i_o_n___t_a_g_s \- 02 - Gestion des Tags 
.PP

.SH "Qu'est-ce qu'un tag ?"
.PP
Un \fBtag\fP est une variable nommée qui occupe une plage de bits dans le buffer CAN (TxData)\&. C'est l'interface principale pour lire et écrire des données\&.

.PP
\fBAnalogie\fP : C'est comme des variables struct, mais mappées directement dans un buffer binaire\&.

.PP
.PP
.SH "Créer un tag : set_tag()"
.PP
.SS "Prototype"
.PP
.nf
int set_tag(const char* tag_name, uint8_t n_bit);
.fi
.PP
.SS "Paramètres"
Paramètre  Type  Description  \fRtag_name\fP  \fRconst char*\fP  Nom unique du tag (ex\&. "SEQ", "HB")  \fRn_bit\fP  \fRuint8_t\fP  Nombre de bits occupés (1 à 16)  
.SS "Valeur de retour"
Consulter \fR\fBdocumentation/API_REFERENCE\&.md\fP\fP pour les codes d'erreur\&.
.SS "Exemples"
.PP
.nf
// Initialisation des tags (dans CAN_setup_TAG())
void CAN_setup_TAG(void) {
    set_tag("SEQ", 3);        // 3 bits pour numéro séquence
    set_tag("HB", 1);         // 1 bit pour watchdog
    set_tag("CI", 2);         // 2 bits pour continuité
    set_tag("AB", 7);         // 7 bits pour batterie (0\-100%)
    set_tag("N2OPS", 16);     // 16 bits pour pression (0\-65535 Pa)
    set_tag("TIME", 16);      // 16 bits pour timestamp (0\-65535 ms)
}
.fi
.PP

.PP
.PP
.SH "Écrire une valeur : set_value()"
.PP
.SS "Prototype"
.PP
.nf
int set_value(const char* tag_name, uint32_t value);
.fi
.PP
.SS "Paramètres"
Paramètre  Type  Description  \fRtag_name\fP  \fRconst char*\fP  Nom du tag à modifier  \fRvalue\fP  \fRuint32_t\fP  Nouvelle valeur à écrire  
.SS "Valeur de retour"
.IP "\(bu" 2
\fBCAN_TG_SUCCESS\fP (0) - Succès
.IP "\(bu" 2
\fBCAN_TG_ERROR_VALUE_TO_BIG\fP - La valeur dépasse les \fRn_bit\fP bits du tag
.IP "\(bu" 2
Autres codes d'erreur - Tag non trouvé, etc\&.
.PP
.SS "Comportement important"
\fBLa valeur est tronquée si elle dépasse la capacité du tag\&.\fP

.PP
Par exemple : 
.PP
.nf
set_tag("SEQ", 3);      // 3 bits \-> plage 0 à 7
set_value("SEQ", 10);   //  Erreur : 10 > 2^3 \- 1 = 7
set_value("SEQ", 5);    //  Ok : écrit 0b101

.fi
.PP
.SS "Exemples d'utilisation"
.PP
.nf
// Dans la boucle principale ou handler
static int seq_counter = 0;

void update_telemetry(void) {
    // Incrémenter et envoyer le numéro de séquence
    seq_counter = (seq_counter + 1) % 8;  // Cycle avec 3 bits (0\-7)
    if(set_value("SEQ", seq_counter) != CAN_TG_SUCCESS) {
        // Erreur\&.\&.\&.
    }

    // Envoyer le statut batterie
    uint8_t battery_percent = read_battery();  // 0\-100
    if(set_value("AB", battery_percent) != CAN_TG_SUCCESS) {
        // Erreur\&.\&.\&.
    }

    // Envoyer une pression
    uint16_t pressure = read_sensor();  // 0\-65535
    if(set_value("N2OPS", pressure) != CAN_TG_SUCCESS) {
        // Erreur\&.\&.\&.
    }

    // Envoyer le timestamp
    uint16_t time_ms = get_timestamp();
    set_value("TIME", time_ms);
}
.fi
.PP

.PP
.PP
.SH "Lire une valeur : get_value()"
.PP
.SS "Prototype"
.PP
.nf
int get_value(const char* tag_name, uint32_t* out_value);
.fi
.PP
.SS "Paramètres"
Paramètre  Type  Description  \fRtag_name\fP  \fRconst char*\fP  Nom du tag à lire  \fRout_value\fP  \fRuint32_t*\fP  Pointeur vers variable de sortie  
.SS "Valeur de retour"
.IP "\(bu" 2
\fBCAN_TG_SUCCESS\fP (0) - Succès, \fR*out_value\fP est valide
.IP "\(bu" 2
Négatif - Code d'erreur
.PP
.SS "Exemples"
.PP
.nf
uint32_t val_seq;
if(get_value("SEQ", &val_seq) == CAN_TG_SUCCESS) {
    printf("Séquence: %u\\n", val_seq);
}

uint32_t val_battery;
if(get_value("AB", &val_battery) == CAN_TG_SUCCESS) {
    printf("Batterie: %u %%\\n", val_battery);
}

uint32_t val_pressure;
if(get_value("N2OPS", &val_pressure) == CAN_TG_SUCCESS) {
    printf("Pression N2O: %u Pa\\n", val_pressure);
}
.fi
.PP

.PP
.PP
.SH "Workflow complet : set / get / send"
.PP
.SS "Scénario d'exemple"
.PP
.nf
#include "TAGCAN\&.h"
#include "stm32f1xx_hal\&.h"

CAN_HandleTypeDef hcan;
uint8_t TxData[8];
CAN_TxHeaderTypeDef TxHeader;
int32_t TxMailbox;

// Étape 1: Initialisation (une fois au démarrage)
void init_system(void) {
    init_com();  // Appelle init_data_container(), init_tag_manager(), set_tag(), etc\&.
}

// Étape 2: Boucle de mise à jour périodique
void periodic_10ms_task(void) {
    static uint8_t seq = 0;
    
    // Préparer les données
    seq = (seq + 1) % 8;
    set_value("SEQ", seq);
    set_value("HB", 1);  // Heartbeat actif
    set_value("AB", read_adc_battery());
    set_value("EDC", get_command_state());
    set_value("TIME", HAL_GetTick());

    // Envoyer le frame CAN
    if(HAL_CAN_AddTxMessage(&hcan, &TxHeader, TxData, &TxMailbox) != HAL_OK) {
        // Erreur d'envoi\&.\&.\&.
    }
}

// Étape 3: Callback de réception (déclenchée par interruption)
void HAL_CAN_RxFifo0MsgPendingCallback(CAN_HandleTypeDef *hcan) {
    CAN_RxHeaderTypeDef RxHeader;
    uint8_t RxData[8];

    // Recevoir le mensaje
    if(HAL_CAN_GetRxMessage(hcan, CAN_RX_FIFO0, &RxHeader, RxData) == HAL_OK) {
        // Copier dans le buffer de TAGCAN
        can_simulate_send_receive(RxData, NULL);  // ou autre traitement

        // Lire les valeurs reçues
        uint32_t remote_seq, remote_battery;
        get_value("SEQ", &remote_seq);
        get_value("AB", &remote_battery);
        
        printf("Nœud distant: SEQ=%u, Batterie=%u%%\\n", remote_seq, remote_battery);
    }
}

int main(void) {
    HAL_Init();
    MX_CAN_Init();
    init_system();

    while(1) {
        periodic_10ms_task();
        // \&.\&.\&.
    }
}
.fi
.PP

.PP
.PP
.SH "Bonnes pratiques"
.PP
À faire  À éviter  Vérifier la valeur de retour de \fR\fBset_value()\fP\fP  Ignorer les codes d'erreur  Vérifier la valeur de retour de \fR\fBget_value()\fP\fP  Utiliser \fRout_value\fP sans vérification  Nommer les tags de façon explicite  Utiliser des noms génériques ("VAL1", "VAL2")  Dimensionner les tags selon les besoins  Allouer trop de bits (gaspillage)  Prévoir le cycle des valeurs (ex: seq 0-7 avec 3 bits)  Dépasser la limite d'un tag sans gérer  Documenter votre schéma de tags  Laisser du code sans commentaires  

.PP
.PP
.SH "Schéma de tags recommandé"
.PP
Pour un système similaire à l'exemple, structurez les tags comme ceci en commentaire :

.PP
.PP
.nf
/*
 * SCHÉMA DE TAGS CAN (ID 0x123)
 * ══════════════════════════════════════════════════════════════
 * Byte 0: [HB(1) | SEQ(3) | CI(2) | XX(2)]
 * Byte 1: [AB(7) | YY(1)]
 * Byte 2\-3: [EDC(4) | PADDING(12)]
 * Byte 4\-5: [N2OPS(16)]       \-\- Pression N2O (Pa)
 * Byte 6\-7: [TLC(12) | N2ODVS(1) | N2OIV(1) | N2OMV(1) | XX(1)]
 *
 * Total: 15 bits utilisés, reste pour extension
 */
.fi
.PP

.PP
