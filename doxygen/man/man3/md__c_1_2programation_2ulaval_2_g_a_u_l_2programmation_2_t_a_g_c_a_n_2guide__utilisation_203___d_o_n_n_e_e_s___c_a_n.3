.TH "md__c_1_2programation_2ulaval_2_g_a_u_l_2programmation_2_t_a_g_c_a_n_2guide__utilisation_203___d_o_n_n_e_e_s___c_a_n" 3 "TAGCAN" \" -*- nroff -*-
.ad l
.nh
.SH NAME
md__c_1_2programation_2ulaval_2_g_a_u_l_2programmation_2_t_a_g_c_a_n_2guide__utilisation_203___d_o_n_n_e_e_s___c_a_n \- 03 - Manipulation du Buffer de Données CAN 
.PP

.SH "Objectif"
.PP
Comprendre comment gérer le buffer de données CAN (\fR\fBTxData\fP\fP et \fR\fBRxData\fP\fP) au-delà de la simple interface des tags\&.

.PP
.PP
.SH "Structure du buffer CAN"
.PP
.SS "Taille et format"
.PP
.nf
uint8_t TxData[8];    // Buffer de transmission (8 octets = CAN standard)
uint8_t RxData[8];    // Buffer de réception (8 octets)
.fi
.PP

.PP
Le buffer CAN est toujours de \fB8 octets\fP (64 bits) pour un frame standard CAN\&.
.SS "Hiérarchie"
Niveau  Composant  Responsabilité  \fBHaut\fP  Application  Appelle \fR\fBset_value()\fP\fP, \fR\fBget_value()\fP\fP  \fBMoyen\fP  Data Container (TAGCAN)  Mappe les tags dans le buffer  \fBBas\fP  Buffer \fR\fBTxData\fP[8]\fP / \fR\fBRxData\fP[8]\fP  Storiage binaire brut  \fBTrès bas\fP  HAL CAN STM32  Envoi/réception matérielle  

.PP
.PP
.SH "Fonctions de gestion du buffer"
.PP
.SS "1 init_data_container()"
Réinitialise le buffer à zéro\&.

.PP
.PP
.nf
void init_data_container(void);
.fi
.PP

.PP
\fBEffet\fP :
.IP "\(bu" 2
Tous les octets de \fR\fBTxData\fP[8]\fP -> 0
.IP "\(bu" 2
Appelé manuellement si vous voulez "effacer" les données
.PP

.PP
\fBExemple\fP : 
.PP
.nf
// Avant:  TxData = {0x12, 0x34, 0x56, \&.\&.\&.}
init_data_container();
// Après:  TxData = {0x00, 0x00, 0x00, \&.\&.\&.}

.fi
.PP

.PP
.PP
.SS "2 set_val_TxData()"
Copie un tableau \fBexterne\fP dans le buffer global \fR\fBTxData\fP\fP\&.

.PP
.PP
.nf
void set_val_TxData(uint8_t *TxDataArray);
.fi
.PP

.PP
\fBUtile pour\fP :
.IP "\(bu" 2
Charger des données pré-formatées
.IP "\(bu" 2
Importer des données d'une autre source
.IP "\(bu" 2
Tester sans passer par les tags
.PP

.PP
\fBExemple\fP : 
.PP
.nf
uint8_t raw_data[8] = {0xAA, 0xBB, 0xCC, 0xDD, 0xEE, 0xFF, 0x00, 0x11};
set_val_TxData(raw_data);  // Copie raw_data \-> TxData

// Après cet appel:
// TxData[0] = 0xAA
// TxData[1] = 0xBB
// \&.\&.\&. et cetera

//  Les tags ne voient PAS cette modification directement
// Vous travaillez maintenant "en dehors" du système de tags

.fi
.PP

.PP
.PP
.SS "3 can_simulate_send_receive()"
Simule un envoi/réception CAN par copie buffer-à-buffer\&.

.PP
.PP
.nf
void can_simulate_send_receive(uint8_t* tx_buffer, uint8_t* rx_buffer);
.fi
.PP

.PP
\fBCas d'usage\fP :
.IP "\(bu" 2
Tests de la logique sans matériel CAN
.IP "\(bu" 2
Vérifier que les données écrites sont bien formatées
.IP "\(bu" 2
Boucle locale pour déboguer
.PP

.PP
\fBExemple\fP : 
.PP
.nf
uint8_t tx[8] = {0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00};
uint8_t rx[8];

// Écrire des données dans tx
set_value("SEQ", 3);
can_simulate_send_receive(TxData, rx);  // Simule envoi/réception

// rx contient maintenant une copie de TxData
memcpy(rx, TxData, 8);  // Équivalent à:
                         // can_simulate_send_receive(TxData, rx);

.fi
.PP

.PP
.PP
.SH "Workflow complet : Écriture -> Envoi -> Réception"
.PP
.SS "Émission (Tx)"
.PP
.nf
Votre application
        ↓
    set_value("SEQ", 5)
    set_value("AB", 75)
    \&.\&.\&.
        ↓
   TxData[8] (rempli par TAGCAN)
        ↓
   Transmission CAN (HAL)
.fi
.PP
.SS "Code d'émission"
.PP
.nf
#include "TAGCAN\&.h"

extern CAN_HandleTypeDef hcan;
extern uint8_t TxData[8];
extern CAN_TxHeaderTypeDef TxHeader;
extern int32_t TxMailbox;

void send_can_frame(void) {
    // Étape 1: Réinitialiser le buffer (optionnel)
    // init_data_container();  // Si vous voulez un buffer vierge

    // Étape 2: Écrire les données via les tags
    set_value("SEQ", 5);
    set_value("HB", 1);
    set_value("AB", 75);
    set_value("N2OPS", 2500);

    // Étape 3: Envoyer via CAN
    HAL_Status = HAL_CAN_AddTxMessage(&hcan, &TxHeader, TxData, &TxMailbox);
    if(HAL_Status != HAL_OK) {
        printf("Erreur d'envoi CAN\\n");
    }
}
.fi
.PP
.SS "Réception (Rx)"
.PP
.nf
   Bus CAN
       ↓
Réception CAN (HAL)
       ↓
   RxData[8]
       ↓
 Votre application récupère les données
 via get_value() ou directement dans RxData[8]
.fi
.PP
.SS "Code de réception"
.PP
.nf
void HAL_CAN_RxFifo0MsgPendingCallback(CAN_HandleTypeDef *hcan) {
    CAN_RxHeaderTypeDef RxHeader;
    uint8_t RxData[8];

    // Étape 1: Recevoir le message via HAL
    if(HAL_CAN_GetRxMessage(hcan, CAN_RX_FIFO0, &RxHeader, RxData) != HAL_OK) {
        return;  // Erreur
    }

    // Étape 2a: Utiliser les données directement (acccès brut)
    printf("Octet 0: 0x%02X\\n", RxData[0]);
    printf("Octet 1: 0x%02X\\n", RxData[1]);

    // OU

    // Étape 2b: Interpréter via les tags
    // (si vous avez le même schéma de tags côté récepteur)
    uint32_t seq, battery;
    if(RxData[0] & 0x38) {  // Bits 3\-5 contiennent possibly SEQ
        // Extraire manuellement\&.\&.\&.
    }

    // Ou utiliser les fonctions TAGCAN si vous avez copié RxData dans TxData:
    memcpy(TxData, RxData, 8);  // Copier RxData \-> TxData
    if(get_value("SEQ", &seq) == CAN_TG_SUCCESS) {
        printf("Numéro de séquence distant: %u\\n", seq);
    }
}
.fi
.PP

.PP
.PP
.SH "Directement lire/écrire les octets"
.PP
.SS "Lecture directe"
.PP
.nf
// Accéder directement à un octet
uint8_t byte0 = TxData[0];  // Premier octet
uint8_t byte7 = TxData[7];  // Dernier octet

// Accéder à un bit spécifique
uint8_t bit3 = (TxData[0] >> 3) & 1;  // Bit 3 de l'octet 0
.fi
.PP
.SS "Écriture directe"
.PP
.nf
// Écrire un octet entier
TxData[0] = 0xA5;  // Écrit 0b10100101

// Modifier un bit spécifique
TxData[0] |= (1 << 3);   // Mettre à 1 le bit 3
TxData[0] &= ~(1 << 3);  // Mettre à 0 le bit 3

// Bitmask pour plusieurs bits
TxData[0] = (TxData[0] & 0xF0) | 0x05;  // Garder les 4 bits hauts, définir bas à 0x05
.fi
.PP

.PP
.PP
.SH "Pièges courants"
.PP
Piège  Description  Solution  \fBMélanger accès direct et tags\fP  Écrire un octet directement, puis utiliser \fR\fBget_value()\fP\fP peut être confus  Soyez cohérent: ou tags, ou accès brut  \fBOublier le \fRmemcpy()\fP\fP  Recevoir \fR\fBRxData\fP\fP, mais essayer de lire avec \fR\fBget_value()\fP\fP sans copier  Toujours copier \fR\fBRxData\fP\fP -> \fR\fBTxData\fP\fP avant \fR\fBget_value()\fP\fP  \fBBuffer réutilisé\fP  Si \fR\fBset_value()\fP\fP change l'ordre de allocation des tags  Pas vraiment un piège, mais attention si tags réordonnés  \fBDébordement de bits\fP  Écrire un octet directement sans respecter le schéma de tags  Documentez votre layout de tags !  

.PP
.PP
.SH "Tableau d'aide : Qui fait quoi ?"
.PP
Tâche  Fonction  Détails  Vider le buffer  \fR\fBinit_data_container()\fP\fP  Remplace TxData par des zéros  Écrire une valeur nommée  \fRset_value(tag, val)\fP  Via l'interface des tags  Lire une valeur nommée  \fR\fBget_value\fP(tag, &val)\fP  Via l'interface des tags  Charger des données brutes  \fRset_val_TxData(arr)\fP  Copie un tableau externe  Tester localement  \fR\fBcan_simulate_send_receive()\fP\fP  Simule une boucle locale  Envoyer sur le bus  \fRHAL_CAN_AddTxMessage()\fP  Transport matériel (HAL STM32)  Recevoir du bus  \fRHAL_CAN_GetRxMessage()\fP  Transport matériel (HAL STM32)  

.PP
.PP
.SH "Exemple : Envoi -> Réception -> Traitement"
.PP
.PP
.nf
#include "TAGCAN\&.h"
#include "stm32f1xx_hal\&.h"

extern CAN_HandleTypeDef hcan;
extern uint8_t TxData[8], RxData[8];
extern CAN_TxHeaderTypeDef TxHeader;
extern int32_t TxMailbox;

// Tâche d'émission (toutes les 10ms)
void task_tx_10ms(void) {
    static uint8_t seq = 0;
    seq = (seq + 1) % 8;

    // Écrire les données
    set_value("SEQ", seq);
    set_value("HB", 1);
    set_value("AB", read_battery_percent());

    // Envoyer
    HAL_CAN_AddTxMessage(&hcan, &TxHeader, TxData, &TxMailbox);
}

// Callback de réception (IRQ)
void HAL_CAN_RxFifo0MsgPendingCallback(CAN_HandleTypeDef *hcan) {
    CAN_RxHeaderTypeDef RxHeader;
    uint8_t RxDataLocal[8];

    HAL_CAN_GetRxMessage(hcan, CAN_RX_FIFO0, &RxHeader, RxDataLocal);

    // Voir directement les octets reçus
    printf("Reçu: ");
    for(int i = 0; i < 8; i++) {
        printf("%02X ", RxDataLocal[i]);
    }
    printf("\\n");

    // Si le même schéma de tags : interpréter via TAGCAN
    memcpy(TxData, RxDataLocal, 8);
    uint32_t remote_seq, remote_battery;
    get_value("SEQ", &remote_seq);
    get_value("AB", &remote_battery);
    printf("Séquence: %u, Batterie: %u%%\\n", remote_seq, remote_battery);
}

int main(void) {
    HAL_Init();
    MX_CAN_Init();
    init_com();

    // Timer pour task_tx_10ms()
    // \&.\&.\&.

    while(1) {
        // Boucle principale
    }
}
.fi
.PP

