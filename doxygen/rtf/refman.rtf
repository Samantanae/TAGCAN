    printf({\cf22 "\\n\\n"});\par
\par
    {\cf20 // \'C9tape 3: Simuler envoi -> r\'E9ception}\par
    printf({\cf22 "Simulation envoi/r\'E9ception...\\n"});\par
    can_simulate_send_receive(TxData, RxData);\par
\par
    {\cf20 // V\'E9rifier}\par
    printf({\cf22 "Buffer RxData: "});\par
    {\cf19 for}({\cf18 int} i = 0; i < 8; i++) \{\par
        printf({\cf22 "%02X "}, RxData[i]);\par
    \}\par
    printf({\cf22 "\\n\\n"});\par
\par
    {\cf20 // \'C9tape 4: Lire les donn\'E9es re\'E7ues}\par
    printf({\cf22 "Lecture des donn\'E9es re\'E7ues...\\n"});\par
    memcpy(TxData, RxData, 8);  {\cf20 // Copier pour lecture}\par
\par
    uint32_t seq, sens_a, sens_b;\par
    get_value({\cf22 "SEQ"}, &seq);\par
    get_value({\cf22 "SENSOR_A"}, &sens_a);\par
    get_value({\cf22 "SENSOR_B"}, &sens_b);\par
\par
    printf({\cf22 "SEQ = %u\\n"}, (uint8_t)seq);\par
    printf({\cf22 "SENSOR_A = %u\\n"}, (uint8_t)sens_a);\par
    printf({\cf22 "SENSOR_B = %u\\n"}, (uint16_t)sens_b);\par
\par
    {\cf20 // V\'E9rifier}\par
    {\cf19 if}(seq == 5 && sens_a == 42 && sens_b == 1000) \{\par
        printf({\cf22 "\\n TEST R\'C9USSI!\\n"});\par
    \} {\cf19 else} \{\par
        printf({\cf22 "\\n TEST \'C9CHOU\'C9!\\n"});\par
    \}\par
\}\par
\par
{\cf18 int} main({\cf18 void}) \{\par
    test_local_loop();\par
    {\cf19 return} 0;\par
\}\par
}
