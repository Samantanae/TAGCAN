{\tc\tcl3 \v Sc\'E9nario d'exemple}
{
\par
\pard\plain \s40\li0\widctlpar\adjustright \shading1000\cbpat8 \f2\fs16\cgrid {\cf21 #include "TAGCAN.h"}\par
{\cf21 #include "stm32f1xx_hal.h"}\par
\par
CAN_HandleTypeDef hcan;\par
uint8_t TxData[8];\par
CAN_TxHeaderTypeDef TxHeader;\par
int32_t TxMailbox;\par
\par
{\cf20 // \'C9tape 1: Initialisation (une fois au d\'E9marrage)}\par
{\cf18 void} init_system({\cf18 void}) \{\par
    init_com();  {\cf20 // Appelle init_data_container(), init_tag_manager(), set_tag(), etc.}\par
\}\par
\par
{\cf20 // \'C9tape 2: Boucle de mise \'E0 jour p\'E9riodique}\par
{\cf18 void} periodic_10ms_task({\cf18 void}) \{\par
    {\cf17 static} uint8_t seq = 0;\par
    \par
    {\cf20 // Pr\'E9parer les donn\'E9es}\par
    seq = (seq + 1) % 8;\par
    set_value({\cf22 "SEQ"}, seq);\par
    set_value({\cf22 "HB"}, 1);  {\cf20 // Heartbeat actif}\par
    set_value({\cf22 "AB"}, read_adc_battery());\par
    set_value({\cf22 "EDC"}, get_command_state());\par
    set_value({\cf22 "TIME"}, HAL_GetTick());\par
\par
    {\cf20 // Envoyer le frame CAN}\par
    {\cf19 if}(HAL_CAN_AddTxMessage(&hcan, &TxHeader, TxData, &TxMailbox) != HAL_OK) \{\par
        {\cf20 // Erreur d'envoi...}\par
    \}\par
\}\par
\par
{\cf20 // \'C9tape 3: Callback de r\'E9ception (d\'E9clench\'E9e par interruption)}\par
{\cf18 void} HAL_CAN_RxFifo0MsgPendingCallback(CAN_HandleTypeDef *hcan) \{\par
    CAN_RxHeaderTypeDef RxHeader;\par
    uint8_t RxData[8];\par
\par
    {\cf20 // Recevoir le mensaje}\par
    {\cf19 if}(HAL_CAN_GetRxMessage(hcan, CAN_RX_FIFO0, &RxHeader, RxData) == HAL_OK) \{\par
        {\cf20 // Copier dans le buffer de TAGCAN}\par
        can_simulate_send_receive(RxData, NULL);  {\cf20 // ou autre traitement}\par
\par
        {\cf20 // Lire les valeurs re\'E7ues}\par
        uint32_t remote_seq, remote_battery;\par
        get_value({\cf22 "SEQ"}, &remote_seq);\par
        get_value({\cf22 "AB"}, &remote_battery);\par
        \par
        printf({\cf22 "N\'9Cud distant: SEQ=%u, Batterie=%u%%\\n"}, remote_seq, remote_battery);\par
    \}\par
\}\par
\par
{\cf18 int} main({\cf18 void}) \{\par
    HAL_Init();\par
    MX_CAN_Init();\par
    init_system();\par
\par
    {\cf19 while}(1) \{\par
        periodic_10ms_task();\par
        {\cf20 // ...}\par
    \}\par
\}\par
}
\par
