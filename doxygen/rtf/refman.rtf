{{\pard\plain \s2\sb240\sa60\keepn\widctlpar\adjustright \b\f1\fs28\kerning28\cgrid 
D\'E9tails de la configuration interne
\par}
{\tc\tcl2 \v D\'E9tails de la configuration interne}
Voici ce que fait {\f2 {\b CAN_setup_Filter()}}  en d\'E9tail :\par
{
\par
\pard\plain \s40\li0\widctlpar\adjustright \shading1000\cbpat8 \f2\fs16\cgrid CAN_FilterTypeDef* CAN_setup_Filter(int32_t minimum_id, int32_t maximum_id, {\cf18 int} filterBank) \{\par
    CAN_FilterTypeDef canfilterconfig;\par
\par
    {\cf20 // Activer le filtre}\par
    canfilterconfig.FilterActivation = CAN_FILTER_ENABLE;\par
\par
    {\cf20 // S\'E9lectionner le num\'E9ro de banc (0-27)}\par
    canfilterconfig.FilterBank = filterBank;\par
\par
    {\cf20 // Affecter \'E0 FIFO0 (interrupt CAN_IT_RX_FIFO0_MSG_PENDING)}\par
    canfilterconfig.FilterFIFOAssignment = CAN_FILTER_FIFO0;\par
\par
    {\cf20 // Configurer les seuils ID haut et bas}\par
    canfilterconfig.FilterIdHigh = maximum_id << 5;    {\cf20 // Maximum}\par
    canfilterconfig.FilterMaskIdHigh = maximum_id << 5; {\cf20 // Masque}\par
    \par
    canfilterconfig.FilterIdLow = minimum_id;           {\cf20 // Minimum}\par
    canfilterconfig.FilterMaskIdLow = minimum_id;       {\cf20 // Masque}\par
\par
    {\cf20 // Mode de filtrage (masque binaire)}\par
    canfilterconfig.FilterMode = CAN_FILTERMODE_IDMASK;\par
\par
    {\cf20 // R\'E9solution: 32 bits (combinaison High + Low)}\par
    canfilterconfig.FilterScale = CAN_FILTERSCALE_32BIT;\par
\par
    {\cf20 // Assigner les bancs de filtrage au CAN1 (non CAN2)}\par
    canfilterconfig.SlaveStartFilterBank = 20;\par
\par
    {\cf20 // Appliquer la configuration mat\'E9rielle}\par
    HAL_CAN_ConfigFilter(&hcan, &canfilterconfig);\par
\par
    {\cf19 return} &canfilterconfig;\par
\}\par
}
\par
{\pard\widctlpar\brdrb\brdrs\brdrw5\brsp20 \adjustright \par}
\par}
