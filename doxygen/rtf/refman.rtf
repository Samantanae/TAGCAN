{{\pard\plain \s3\sb240\sa60\keepn\widctlpar\adjustright \b\f1\cgrid 
Code complet
\par}
{\tc\tcl3 \v Code complet}
{
\par
\pard\plain \s40\li0\widctlpar\adjustright \shading1000\cbpat8 \f2\fs16\cgrid {\cf20 // =============================================================================}\par
{\cf20 // telemetrie.h}\par
{\cf20 // =============================================================================}\par
\par
{\cf21 #ifndef TELEMETRIE_H_}\par
{\cf21 #define TELEMETRIE_H_}\par
\par
{\cf21 #include "TAGCAN.h"}\par
{\cf21 #include <stdint.h>}\par
\par
{\cf17 typedef} {\cf17 struct }\{\par
    uint8_t seq;\par
    uint8_t heartbeat;\par
    uint8_t battery_percent;\par
    uint16_t reservoir_pressure;\par
    uint16_t timestamp_ms;\par
\} telemetry_data_t;\par
\par
{\cf20 // Initialiser le syst\'E8me de t\'E9l\'E9m\'E9trie}\par
{\cf18 void} telemetry_init({\cf18 void});\par
\par
{\cf20 // Envoyer un paquet de t\'E9l\'E9m\'E9trie}\par
{\cf18 void} telemetry_send({\cf17 const} telemetry_data_t *data);\par
\par
{\cf20 // Traiter un paquet re\'E7u}\par
{\cf18 void} telemetry_handle_rx({\cf17 const} uint8_t rx_data[8]);\par
\par
{\cf21 #endif }{\cf20 /* TELEMETRIE_H_ */}{\cf21 }\par
\par
\par
{\cf20 // =============================================================================}\par
{\cf20 // telemetrie.c}\par
{\cf20 // =============================================================================}\par
\par
{\cf21 #include "telemetrie.h"}\par
{\cf21 #include "stm32f1xx_hal.h"}\par
\par
{\cf17 extern} CAN_HandleTypeDef hcan;\par
{\cf17 extern} uint8_t TxData[8], RxData[8];\par
{\cf17 extern} CAN_TxHeaderTypeDef TxHeader;\par
{\cf17 extern} int32_t TxMailbox;\par
\par
{\cf21 #define TELEMETRY_CAN_ID 0x100}\par
\par
{\cf18 void} telemetry_init({\cf18 void}) \{\par
    {\cf20 // Initialiser TAGCAN}\par
    init_data_container();\par
    init_tag_manager();\par
\par
    {\cf20 // Cr\'E9er les tags}\par
    set_tag({\cf22 "SEQ"}, 3);          {\cf20 // Num\'E9ro de s\'E9quence (0-7)}\par
    set_tag({\cf22 "HB"}, 1);           {\cf20 // Heartbeat (0 ou 1)}\par
    set_tag({\cf22 "BATTERY"}, 7);      {\cf20 // % batterie (0-100)}\par
    set_tag({\cf22 "PRESSURE"}, 16);    {\cf20 // Pression r\'E9servoir (0-65535 Pa)}\par
    set_tag({\cf22 "TIME"}, 16);        {\cf20 // Timestamp (0-65535 ms)}\par
\par
    {\cf20 // Configurer le header CAN}\par
    TxHeader.IDE = CAN_ID_STD;\par
    TxHeader.StdId = TELEMETRY_CAN_ID;\par
    TxHeader.RTR = CAN_RTR_DATA;\par
    TxHeader.DLC = 8;\par
\par
    {\cf20 // Configurer le filtre pour recevoir les t\'E9l\'E9m\'E9tries des autres (ex: 0x101-0x10F)}\par
    CAN_setup_Filter(0x101, 0x10F, 0);\par
\par
    {\cf20 // Activer les interruptions}\par
    {\cf19 if}(HAL_CAN_ActivateNotification(&hcan, CAN_IT_RX_FIFO0_MSG_PENDING) != HAL_OK) \{\par
        Error_Handler();\par
    \}\par
\par
    printf({\cf22 "[Telemetry] Initialized on CAN ID 0x%03X\\n"}, TELEMETRY_CAN_ID);\par
\}\par
\par
{\cf18 void} telemetry_send({\cf17 const} telemetry_data_t *data) \{\par
    {\cf20 // R\'E9initialiser le buffer}\par
    init_data_container();\par
\par
    {\cf20 // \'C9crire les donn\'E9es}\par
    set_value({\cf22 "SEQ"}, data->seq);\par
    set_value({\cf22 "HB"}, data->heartbeat);\par
    set_value({\cf22 "BATTERY"}, data->battery_percent);\par
    set_value({\cf22 "PRESSURE"}, data->reservoir_pressure);\par
    set_value({\cf22 "TIME"}, data->timestamp_ms);\par
\par
    {\cf20 // Envoyer sur le bus}\par
    {\cf19 if}(HAL_CAN_AddTxMessage(&hcan, &TxHeader, TxData, &TxMailbox) != HAL_OK) \{\par
        printf({\cf22 "[Telemetry] ERROR: Failed to send CAN message\\n"});\par
    \} {\cf19 else} \{\par
        printf({\cf22 "[Telemetry] TX: SEQ=%u, BAT=%u%%, PRESSURE=%u Pa\\n"},\par
               data->seq, data->battery_percent, data->reservoir_pressure);\par
    \}\par
\}\par
\par
{\cf18 void} telemetry_handle_rx({\cf17 const} uint8_t rx_data[8]) \{\par
    {\cf20 // Copier les donn\'E9es re\'E7ues dans TxData pour utiliser TAGCAN}\par
    memcpy(TxData, rx_data, 8);\par
\par
    {\cf20 // Lire via les tags}\par
    uint32_t seq, hb, battery, pressure, timestamp;\par
    get_value({\cf22 "SEQ"}, &seq);\par
    get_value({\cf22 "HB"}, &hb);\par
    get_value({\cf22 "BATTERY"}, &battery);\par
    get_value({\cf22 "PRESSURE"}, &pressure);\par
    get_value({\cf22 "TIME"}, &timestamp);\par
\par
    printf({\cf22 "[Telemetry] RX: SEQ=%u, HB=%u, BAT=%u%%, PRESSURE=%u Pa, TIME=%u ms\\n"},\par
           (uint8_t)seq, (uint8_t)hb, (uint8_t)battery, (uint16_t)pressure, (uint16_t)timestamp);\par
\}\par
\par
{\cf20 // =============================================================================}\par
{\cf20 // Callback d'interruption CAN}\par
{\cf20 // =============================================================================}\par
\par
{\cf18 void} HAL_CAN_RxFifo0MsgPendingCallback(CAN_HandleTypeDef *hcan) \{\par
    CAN_RxHeaderTypeDef RxHeader;\par
    uint8_t RxDataLocal[8];\par
\par
    {\cf19 if}(HAL_CAN_GetRxMessage(hcan, CAN_RX_FIFO0, &RxHeader, RxDataLocal) == HAL_OK) \{\par
        {\cf20 // Traiter selon l'ID CAN re\'E7u}\par
        {\cf19 if}((RxHeader.StdId >= 0x101) && (RxHeader.StdId <= 0x10F)) \{\par
            telemetry_handle_rx(RxDataLocal);\par
        \}\par
    \}\par
\}\par
\par
{\cf20 // =============================================================================}\par
{\cf20 // main.c - Boucle principale}\par
{\cf20 // =============================================================================}\par
\par
{\cf20 // T\'E2che d'\'E9mission (10 ms)}\par
{\cf18 void} task_telemetry_10ms({\cf18 void}) \{\par
    {\cf17 static} uint8_t seq = 0;\par
    {\cf17 static} uint32_t last_time = 0;\par
\par
    telemetry_data_t data = \{\par
        .seq = (seq++) % 8,\par
        .heartbeat = 1,\par
        .battery_percent = read_adc_battery(),\par
        .reservoir_pressure = read_sensor_pressure(),\par
        .timestamp_ms = HAL_GetTick() & 0xFFFF\par
    \};\par
\par
    {\cf19 if}((HAL_GetTick() - last_time) >= 10) \{\par
        telemetry_send(&data);\par
        last_time = HAL_GetTick();\par
    \}\par
\}\par
\par
{\cf18 int} main({\cf18 void}) \{\par
    HAL_Init();\par
    MX_CAN_Init();\par
    \par
    telemetry_init();\par
\par
    {\cf20 // Timer pour appeler task_telemetry_10ms() tous les 10ms}\par
    {\cf20 // ...}\par
\par
    {\cf19 while}(1) \{\par
        task_telemetry_10ms();\par
    \}\par
\}\par
}
\par
