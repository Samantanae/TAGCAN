{{\pard\plain \s3\sb240\sa60\keepn\widctlpar\adjustright \b\f1\cgrid 
Sc\'E9nario
\par}
{\tc\tcl3 \v Sc\'E9nario}
Logger tous les messages CAN re\'E7us pour du monitoring.\par
{
\par
\pard\plain \s40\li0\widctlpar\adjustright \shading1000\cbpat8 \f2\fs16\cgrid {\cf20 // =============================================================================}\par
{\cf20 // can_monitor.h}\par
{\cf20 // =============================================================================}\par
\par
{\cf21 #ifndef CAN_MONITOR_H_}\par
{\cf21 #define CAN_MONITOR_H_}\par
\par
{\cf21 #include <stdint.h>}\par
\par
{\cf17 typedef} {\cf17 struct }\{\par
    uint32_t id;\par
    uint8_t dlc;\par
    uint8_t data[8];\par
    uint32_t timestamp_ms;\par
\} can_frame_t;\par
\par
{\cf21 #define CAN_MONITOR_BUFFER_SIZE 100}\par
\par
{\cf18 void} can_monitor_init({\cf18 void});\par
{\cf18 void} can_monitor_log({\cf17 const} can_frame_t *frame);\par
{\cf18 void} can_monitor_dump({\cf18 void});\par
\par
{\cf21 #endif}\par
\par
\par
{\cf20 // =============================================================================}\par
{\cf20 // can_monitor.c}\par
{\cf20 // =============================================================================}\par
\par
{\cf21 #include "can_monitor.h"}\par
{\cf21 #include "stm32f1xx_hal.h"}\par
{\cf21 #include <stdio.h>}\par
{\cf21 #include <string.h>}\par
\par
{\cf17 static} can_frame_t monitor_buffer[CAN_MONITOR_BUFFER_SIZE];\par
{\cf17 static} uint32_t monitor_index = 0;\par
\par
{\cf18 void} can_monitor_init({\cf18 void}) \{\par
    monitor_index = 0;\par
    memset(monitor_buffer, 0, {\cf17 sizeof}(monitor_buffer));\par
    printf({\cf22 "[Monitor] Initialized\\n"});\par
\}\par
\par
{\cf18 void} can_monitor_log({\cf17 const} can_frame_t *frame) \{\par
    {\cf19 if}(monitor_index >= CAN_MONITOR_BUFFER_SIZE) \{\par
        monitor_index = 0;  {\cf20 // Circulaire}\par
    \}\par
\par
    memcpy(&monitor_buffer[monitor_index], frame, {\cf17 sizeof}(can_frame_t));\par
    monitor_index++;\par
\}\par
\par
{\cf18 void} can_monitor_dump({\cf18 void}) \{\par
    printf({\cf22 "\\n=== CAN FRAME LOG ===\\n"});\par
    printf({\cf22 "| Index | ID    | DLC | Data                 | Timestamp |\\n"});\par
    printf({\cf22 "|-------|-------|-----|----------------------|-----------|\\n"});\par
\par
    {\cf19 for}(uint32_t i = 0; i < monitor_index && i < CAN_MONITOR_BUFFER_SIZE; i++) \{\par
        {\cf17 const} can_frame_t *frame = &monitor_buffer[i];\par
\par
        printf({\cf22 "| %5u | 0x%03X | %u   | "}, i, ({\cf18 unsigned})frame->id, frame->dlc);\par
        {\cf19 for}({\cf18 int} j = 0; j < 8; j++) \{\par
            printf({\cf22 "%02X "}, frame->data[j]);\par
        \}\par
        printf({\cf22 "| %9u |\\n"}, ({\cf18 unsigned})frame->timestamp_ms);\par
    \}\par
    printf({\cf22 "\\n"});\par
\}\par
\par
{\cf20 // =============================================================================}\par
{\cf20 // Utilisation dans le callback CAN}\par
{\cf20 // =============================================================================}\par
\par
{\cf18 void} HAL_CAN_RxFifo0MsgPendingCallback(CAN_HandleTypeDef *hcan) \{\par
    CAN_RxHeaderTypeDef RxHeader;\par
    uint8_t RxDataLocal[8];\par
\par
    {\cf19 if}(HAL_CAN_GetRxMessage(hcan, CAN_RX_FIFO0, &RxHeader, RxDataLocal) == HAL_OK) \{\par
        can_frame_t frame = \{\par
            .id = RxHeader.StdId,\par
            .dlc = RxHeader.DLC,\par
            .timestamp_ms = HAL_GetTick()\par
        \};\par
        memcpy(frame.data, RxDataLocal, 8);\par
\par
        can_monitor_log(&frame);\par
    \}\par
\}\par
\par
{\cf20 // =============================================================================}\par
{\cf20 // main.c}\par
{\cf20 // =============================================================================}\par
\par
{\cf18 int} main({\cf18 void}) \{\par
    HAL_Init();\par
    MX_CAN_Init();\par
\par
    can_monitor_init();\par
\par
    {\cf20 // ... votre logique CAN ...}\par
\par
    {\cf20 // Afficher le log apr\'E8s 10 secondes}\par
    HAL_Delay(10000);\par
    can_monitor_dump();\par
\par
    {\cf19 while}(1) \{\par
        {\cf20 // ...}\par
    \}\par
\}\par
}
\par
{\pard\widctlpar\brdrb\brdrs\brdrw5\brsp20 \adjustright \par}
\par}
