00068         {\cf19 if}(n_bits == 16)\{TxData[tag->byte_idx_b] = data_b;\}\par
00069         {\cf19 else}\{\par
00070             {\cf20 // Cas 9..15 bits: insertion partielle dans le byte B.}\par
00071             {\cf20 // Creation du masque binaire}\par
00072             uint8_t mask = prep_mask(bit_pos_b, n_bits - 8);\par
