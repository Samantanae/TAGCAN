{\tc\tcl3 \v Lecture directe}
{
\par
\pard\plain \s40\li0\widctlpar\adjustright \shading1000\cbpat8 \f2\fs16\cgrid {\cf20 // Acc\'E9der directement \'E0 un octet}\par
uint8_t byte0 = TxData[0];  {\cf20 // Premier octet}\par
uint8_t byte7 = TxData[7];  {\cf20 // Dernier octet}\par
\par
{\cf20 // Acc\'E9der \'E0 un bit sp\'E9cifique}\par
uint8_t bit3 = (TxData[0] >> 3) & 1;  {\cf20 // Bit 3 de l'octet 0}\par
}
\par}
{\bkmkstart AAAAAAAAMI}
