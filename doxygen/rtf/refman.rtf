\par
\pard\plain \s40\li0\widctlpar\adjustright \shading1000\cbpat8 \f2\fs16\cgrid {\cf21 #include "com_utils.h"}\par
{\cf21 #include "TAGCAN.h"}\par
\par
{\cf18 void} init_com({\cf18 void}) \{\par
    {\cf20 // \'C9tape 1 : Initialiser les conteneurs de donn\'E9es}\par
    CAN_init_TAGCAN();\par
\par
    {\cf20 // \'C9tape 2 : Cr\'E9er les tags applicatifs}\par
    CAN_setup_TAG();\par
\par
    {\cf20 // \'C9tape 3 : Configurer le header CAN}\par
    CAN_setup_DF(0x123);  {\cf20 // ID CAN = 0x123}\par
\par
    {\cf20 // \'C9tape 4 : Activer la r\'E9ception par interruption}\par
    {\cf19 if}(HAL_CAN_ActivateNotification(&hcan, CAN_IT_RX_FIFO0_MSG_PENDING) != HAL_OK) \{\par
        Error_Handler();\par
    \}\par
\par
    {\cf20 //  Syst\'E8me TAGCAN pr\'EAt !}\par
\}\par
\par
{\cf20 // \'C0 appeler une seule fois dans main() au d\'E9marrage}\par
{\cf18 int} main({\cf18 void}) \{\par
    HAL_Init();\par
    MX_CAN_Init();      {\cf20 // Initialisation du module CAN mat\'E9riel}\par
\par
    init_com();         {\cf20 // Initialisation TAGCAN}\par
\par
    {\cf20 // Boucle principale...}\par
    {\cf19 while}(1) \{\par
        {\cf20 // Votre code}\par
    \}\par
\}\par
}
