{{\pard\plain \s3\sb240\sa60\keepn\widctlpar\adjustright \b\f1\cgrid 
\'C9criture directe
\par}
{\tc\tcl3 \v \'C9criture directe}
{
\par
\pard\plain \s40\li0\widctlpar\adjustright \shading1000\cbpat8 \f2\fs16\cgrid {\cf20 // \'C9crire un octet entier}\par
TxData[0] = 0xA5;  {\cf20 // \'C9crit 0b10100101}\par
\par
{\cf20 // Modifier un bit sp\'E9cifique}\par
TxData[0] |= (1 << 3);   {\cf20 // Mettre \'E0 1 le bit 3}\par
TxData[0] &= ~(1 << 3);  {\cf20 // Mettre \'E0 0 le bit 3}\par
\par
{\cf20 // Bitmask pour plusieurs bits}\par
TxData[0] = (TxData[0] & 0xF0) | 0x05;  {\cf20 // Garder les 4 bits hauts, d\'E9finir bas \'E0 0x05}\par
}
\par
