Exemple : Envoi -> R\'E9ception -> Traitement
\par}
{\tc\tcl2 \v Exemple : Envoi -> R\'E9ception -> Traitement}
{
\par
\pard\plain \s40\li0\widctlpar\adjustright \shading1000\cbpat8 \f2\fs16\cgrid {\cf21 #include "TAGCAN.h"}\par
{\cf21 #include "stm32f1xx_hal.h"}\par
\par
{\cf17 extern} CAN_HandleTypeDef hcan;\par
{\cf17 extern} uint8_t TxData[8], RxData[8];\par
{\cf17 extern} CAN_TxHeaderTypeDef TxHeader;\par
{\cf17 extern} int32_t TxMailbox;\par
\par
{\cf20 // T\'E2che d'\'E9mission (toutes les 10ms)}\par
{\cf18 void} task_tx_10ms({\cf18 void}) \{\par
    {\cf17 static} uint8_t seq = 0;\par
    seq = (seq + 1) % 8;\par
\par
    {\cf20 // \'C9crire les donn\'E9es}\par
    set_value({\cf22 "SEQ"}, seq);\par
    set_value({\cf22 "HB"}, 1);\par
    set_value({\cf22 "AB"}, read_battery_percent());\par
\par
    {\cf20 // Envoyer}\par
    HAL_CAN_AddTxMessage(&hcan, &TxHeader, TxData, &TxMailbox);\par
\}\par
\par
{\cf20 // Callback de r\'E9ception (IRQ)}\par
{\cf18 void} HAL_CAN_RxFifo0MsgPendingCallback(CAN_HandleTypeDef *hcan) \{\par
    CAN_RxHeaderTypeDef RxHeader;\par
    uint8_t RxDataLocal[8];\par
\par
    HAL_CAN_GetRxMessage(hcan, CAN_RX_FIFO0, &RxHeader, RxDataLocal);\par
\par
    {\cf20 // Voir directement les octets re\'E7us}\par
    printf({\cf22 "Re\'E7u: "});\par
    {\cf19 for}({\cf18 int} i = 0; i < 8; i++) \{\par
        printf({\cf22 "%02X "}, RxDataLocal[i]);\par
    \}\par
    printf({\cf22 "\\n"});\par
\par
    {\cf20 // Si le m\'EAme sch\'E9ma de tags : interpr\'E9ter via TAGCAN}\par
    memcpy(TxData, RxDataLocal, 8);\par
    uint32_t remote_seq, remote_battery;\par
    get_value({\cf22 "SEQ"}, &remote_seq);\par
    get_value({\cf22 "AB"}, &remote_battery);\par
    printf({\cf22 "S\'E9quence: %u, Batterie: %u%%\\n"}, remote_seq, remote_battery);\par
\}\par
\par
{\cf18 int} main({\cf18 void}) \{\par
    HAL_Init();\par
    MX_CAN_Init();\par
    init_com();\par
\par
    {\cf20 // Timer pour task_tx_10ms()}\par
    {\cf20 // ...}\par
\par
    {\cf19 while}(1) \{\par
        {\cf20 // Boucle principale}\par
    \}\par
\}\par
}
\par
