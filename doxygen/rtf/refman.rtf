00044 CAN_TG_STATUE set_value({\cf17 const} {\cf18 char}* tag_name, uint32_t value)\par
00045 \{\par
00046     {\cf17 const} TagDef* tag = get_tag_def(tag_name);\par
00047     {\cf19 if} (!tag) {\cf19 return} -3; {\cf20 // Tag non trouve}\par
00048 \par
00049     {\cf17 const} uint8_t n_bits = tag->n_bits;\par
00050     {\cf17 const} uint8_t bit_pos_a = tag->bit_pos_a;\par
00051     {\cf17 const} uint8_t bit_pos_b = tag->bit_pos_b;\par
00052     {\cf17 const} int8_t byte_idx_a = tag->byte_idx_a;\par
00053     {\cf17 const} int8_t byte_idx_b = tag->byte_idx_b;\par
00054 \par
00055     {\cf20 // Verification du depassement de la valeur selon n_bits}\par
00056     {\cf19 if} (tag->n_bits < 32 && value >= (1ULL << tag->n_bits))\par
00057     \{\par
00058         printf({\cf22 "[ERREUR] Valeur \'D9\'AAu trop grande pour le tag \'D9\'AAs (\'D9\'AAu bits)\\n"}, value, tag_name, tag->n_bits);\par
00059         {\cf19 return} CAN_TG_ERROR_VALUE_TO_BIG;\par
00060     \}\par
00061 \par
00062     {\cf20 // Cas des valeurs sur plus de 8 bits: repartition entre partie A et partie B.}\par
00063     {\cf19 if}(n_bits > 8)\{\par
00064         uint8_t data_b = (value & 0xFF00) >> 8;\par
00065         uint8_t data_a = (value & 0x00FF);\par
