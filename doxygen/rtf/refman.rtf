{\tc\tcl3 \v Code d'\'E9mission}
{
\par
\pard\plain \s40\li0\widctlpar\adjustright \shading1000\cbpat8 \f2\fs16\cgrid {\cf21 #include "TAGCAN.h"}\par
\par
{\cf17 extern} CAN_HandleTypeDef hcan;\par
{\cf17 extern} uint8_t TxData[8];\par
{\cf17 extern} CAN_TxHeaderTypeDef TxHeader;\par
{\cf17 extern} int32_t TxMailbox;\par
\par
{\cf18 void} send_can_frame({\cf18 void}) \{\par
    {\cf20 // \'C9tape 1: R\'E9initialiser le buffer (optionnel)}\par
    {\cf20 // init_data_container();  // Si vous voulez un buffer vierge}\par
\par
    {\cf20 // \'C9tape 2: \'C9crire les donn\'E9es via les tags}\par
    set_value({\cf22 "SEQ"}, 5);\par
    set_value({\cf22 "HB"}, 1);\par
    set_value({\cf22 "AB"}, 75);\par
    set_value({\cf22 "N2OPS"}, 2500);\par
\par
    {\cf20 // \'C9tape 3: Envoyer via CAN}\par
    HAL_Status = HAL_CAN_AddTxMessage(&hcan, &TxHeader, TxData, &TxMailbox);\par
    {\cf19 if}(HAL_Status != HAL_OK) \{\par
        printf({\cf22 "Erreur d'envoi CAN\\n"});\par
    \}\par
\}\par
}
\par}
