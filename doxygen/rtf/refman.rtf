\par
{\cf18 void} test_local_loop({\cf18 void}) \{\par
    printf({\cf22 "=== TEST BOUCLE LOCALE TAGCAN ===\\n\\n"});\par
\par
    {\cf20 // \'C9tape 1: Initialiser}\par
    init_data_container();\par
    init_tag_manager();\par
\par
    set_tag({\cf22 "SEQ"}, 3);\par
    set_tag({\cf22 "SENSOR_A"}, 8);\par
    set_tag({\cf22 "SENSOR_B"}, 12);\par
\par
    printf({\cf22 " Initialis\'E9\\n\\n"});\par
\par
    {\cf20 // \'C9tape 2: \'C9crire les donn\'E9es}\par
    printf({\cf22 "\'C9criture des donn\'E9es...\\n"});\par
    set_value({\cf22 "SEQ"}, 5);\par
    set_value({\cf22 "SENSOR_A"}, 42);\par
    set_value({\cf22 "SENSOR_B"}, 1000);\par
\par
    {\cf20 // Afficher le buffer brut}\par
    printf({\cf22 "Buffer TxData: "});\par
    {\cf19 for}({\cf18 int} i = 0; i < 8; i++) \{\par
        printf({\cf22 "%02X "}, TxData[i]);\par
