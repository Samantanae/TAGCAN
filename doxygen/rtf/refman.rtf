00144 CAN_TG_STATUE find_byte_with_enoung_space(uint8_t siz, int8_t* retur_var)\par
00145 \{\par
00146     {\cf20 // Pour > 8 bits, la 1re recherche se limite a un bloc de 8 bits.}\par
00147     {\cf19 if}(siz > 8)\par
00148     \{\par
00149         siz = 8;\par
00150     \}\par
00151     {\cf20 // Pour les tailles impaires: priorite aux bytes a place impaire restante.}\par
00152     {\cf19 if}(siz%2 > 0)\par
00153     \{\par
00154         {\cf20 // Heuristique de placement.}\par
00155         {\cf19 for} (int8_t i = 0; i < N_BYTES; i++)\par
00156         \{\par
00157             \{\par
00158                 {\cf19 if}(((8 - g_bytes_used[i])%2 > 0) && ((8 - g_bytes_used[i]) >= siz))\par
00159                 \{\par
00160                     *retur_var=i;\par
00161                     {\cf19 return} CAN_TG_SUCCESS;\par
00162                 \}\par
00163             \}\par
00164         \}\par
00165     \}\par
00166     {\cf20 // Sinon, recherche sequentielle standard.}\par
00167     {\cf19 for} (int8_t i = 0; i < N_BYTES; i++)\par
00168     \{\par
00169         {\cf19 if}((8 - g_bytes_used[i]) >= siz)\par
00170         \{\par
00171             *retur_var=i;\par
00172             {\cf19 return} CAN_TG_SUCCESS;\par
00173         \}\par
00174     \}\par
00175     {\cf19 return} CAN_TG_ERROR_NOT_ENOUNG_SPACE_;\par
00176 \}\par
00177 \par
00178 \par
00187 \par
00188 CAN_TG_STATUE find_byte2_with_enoung_space(uint8_t siz_total, int8_t posi_premier_bit,int8_t* retur_var)\par
00189 \{\par
00190     uint8_t siz = siz_total - 8;\par
00191     {\cf20 // Meme heuristique que find_byte_with_enoung_space.}\par
00192     {\cf19 if}(siz%2 > 0)\par
00193     \{\par
00194         {\cf20 // Priorite aux bytes dont l'espace restant est impair.}\par
00195         {\cf19 for} (int8_t i = 0; i < N_BYTES; i++)\par
00196         \{\par
00197             {\cf19 if}(posi_premier_bit == i)\par
00198             \{\par
00199                 {\cf19 continue};\par
00200             \}\par
00201             {\cf19 if}(((8 - g_bytes_used[i])%2 > 0) && ((8 - g_bytes_used[i]) >= siz))\par
00202             \{\par
00203                 *retur_var=i;\par
00204                 {\cf19 return} CAN_TG_SUCCESS;\par
00205             \}\par
00206         \}\par
00207     \}\par
00208     {\cf20 // Sinon, recherche sequentielle standard.}\par
00209     {\cf19 for} (uint8_t i = 0; i < N_BYTES; i++)\par
00210     \{\par
00211         {\cf19 if}(posi_premier_bit == i)\par
00212         \{\par
00213             {\cf19 continue};\par
00214         \}\par
00215         {\cf19 if}((8 - g_bytes_used[i]) >= siz)\par
00216         \{\par
00217             *retur_var=i;\par
00218             {\cf19 return} CAN_TG_SUCCESS;\par
00219         \}\par
00220     \}\par
00221     {\cf19 return} CAN_TG_ERROR_NOT_ENOUNG_SPACE_;\par
00222 \}\par
00223 \par
