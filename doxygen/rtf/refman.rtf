{\cf20 // commandes.h}\par
{\cf20 // =============================================================================}\par
\par
{\cf21 #ifndef COMMANDES_H_}\par
{\cf21 #define COMMANDES_H_}\par
\par
{\cf21 #include "TAGCAN.h"}\par
{\cf21 #include <stdint.h>}\par
\par
{\cf20 // IDs CAN}\par
{\cf21 #define CMD_CAN_ID_TX       0x200}\par
{\cf21 #define CMD_CAN_ID_RX_BASE  0x201}\par
\par
{\cf20 // Commandes possibles}\par
{\cf17 typedef} {\cf17 enum} \{\par
    CMD_SERVO_OFF = 0,\par
    CMD_SERVO_ON = 1,\par
    CMD_SERVO_PULSE = 2\par
\} cmd_type_t;\par
\par
{\cf17 typedef} {\cf17 struct }\{\par
    uint8_t device_id;      {\cf20 // Quel servomoteur ? (1-3)}\par
    cmd_type_t command;     {\cf20 // Quelle commande ?}\par
    uint8_t parameter;      {\cf20 // Param\'E8tre optionnel (ex: pulse width)}\par
\} command_t;\par
\par
{\cf17 typedef} {\cf17 struct }\{\par
    uint8_t device_id;\par
    uint8_t status;         {\cf20 // 0=erreur, 1=ok}\par
    uint8_t feedback;       {\cf20 // Retour d'\'E9tat}\par
\} response_t;\par
\par
{\cf18 void} commands_init({\cf18 void});\par
{\cf18 void} commands_send({\cf17 const} command_t *cmd);\par
{\cf18 void} commands_handle_response(uint8_t device_id, {\cf17 const} uint8_t rx_data[8]);\par
\par
{\cf21 #endif}\par
\par
\par
{\cf20 // =============================================================================}\par
{\cf20 // commandes.c}\par
{\cf20 // =============================================================================}\par
\par
{\cf21 #include "commandes.h"}\par
{\cf21 #include "stm32f1xx_hal.h"}\par
\par
{\cf17 extern} CAN_HandleTypeDef hcan;\par
{\cf17 extern} uint8_t TxData[8];\par
{\cf17 extern} CAN_TxHeaderTypeDef TxHeader;\par
{\cf17 extern} int32_t TxMailbox;\par
\par
{\cf18 void} commands_init({\cf18 void}) \{\par
    {\cf20 // Initialiser TAGCAN}\par
    init_data_container();\par
    init_tag_manager();\par
\par
    {\cf20 // Tags pour les commandes ENVOY\'C9ES}\par
    set_tag({\cf22 "DEV_ID"}, 2);       {\cf20 // ID du p\'E9riph\'E9rique (0-3)}\par
    set_tag({\cf22 "CMD_TYPE"}, 2);     {\cf20 // Type de commande (0-3)}\par
    set_tag({\cf22 "PARAM"}, 8);        {\cf20 // Param\'E8tre (0-255)}\par
\par
    {\cf20 // Configuration du header TX}\par
    TxHeader.IDE = CAN_ID_STD;\par
    TxHeader.StdId = CMD_CAN_ID_TX;\par
    TxHeader.RTR = CAN_RTR_DATA;\par
    TxHeader.DLC = 8;\par
\par
    {\cf20 // Filtre pour les r\'E9ponses des esclaves (0x201-0x203)}\par
    CAN_setup_Filter(0x201, 0x203, 0);\par
\par
    {\cf20 // Interruptions}\par
    {\cf19 if}(HAL_CAN_ActivateNotification(&hcan, CAN_IT_RX_FIFO0_MSG_PENDING) != HAL_OK) \{\par
        Error_Handler();\par
    \}\par
\par
    printf({\cf22 "[Commands] Initialized\\n"});\par
\}\par
\par
{\cf18 void} commands_send({\cf17 const} command_t *cmd) \{\par
    init_data_container();\par
\par
    set_value({\cf22 "DEV_ID"}, cmd->device_id);\par
    set_value({\cf22 "CMD_TYPE"}, cmd->command);\par
    set_value({\cf22 "PARAM"}, cmd->parameter);\par
\par
    {\cf19 if}(HAL_CAN_AddTxMessage(&hcan, &TxHeader, TxData, &TxMailbox) != HAL_OK) \{\par
        printf({\cf22 "[Commands] ERROR: Send failed\\n"});\par
    \} {\cf19 else} \{\par
        printf({\cf22 "[Commands] TX: Device=%u, Command=%u, Param=%u\\n"},\par
               cmd->device_id, cmd->command, cmd->parameter);\par
    \}\par
\}\par
\par
{\cf18 void} commands_handle_response(uint8_t device_id, {\cf17 const} uint8_t rx_data[8]) \{\par
    memcpy(TxData, rx_data, 8);\par
\par
    uint32_t status, feedback;\par
    get_value({\cf22 "DEV_ID"}, NULL);  {\cf20 // Ou extraire directement}\par
    get_value({\cf22 "STATUS"}, &status);\par
    get_value({\cf22 "FEEDBACK"}, &feedback);\par
\par
    printf({\cf22 "[Commands] RX Response from Device %u: Status=%u, Feedback=%u\\n"},\par
           device_id, (uint8_t)status, (uint8_t)feedback);\par
\}\par
\par
{\cf18 void} HAL_CAN_RxFifo0MsgPendingCallback(CAN_HandleTypeDef *hcan) \{\par
    CAN_RxHeaderTypeDef RxHeader;\par
    uint8_t RxDataLocal[8];\par
\par
    {\cf19 if}(HAL_CAN_GetRxMessage(hcan, CAN_RX_FIFO0, &RxHeader, RxDataLocal) == HAL_OK) \{\par
        uint8_t device_id = RxHeader.StdId - CMD_CAN_ID_RX_BASE + 1;\par
        {\cf19 if}((RxHeader.StdId >= 0x201) && (RxHeader.StdId <= 0x203)) \{\par
            commands_handle_response(device_id, RxDataLocal);\par
        \}\par
    \}\par
\}\par
\par
{\cf20 // =============================================================================}\par
{\cf20 // main.c - Exemple d'utilisation}\par
{\cf20 // =============================================================================}\par
\par
{\cf18 int} main({\cf18 void}) \{\par
    HAL_Init();\par
    MX_CAN_Init();\par
\par
    commands_init();\par
\par
    {\cf20 // Envoyer la commande "Allumer servomoteur 1"}\par
    command_t cmd1 = \{\par
        .device_id = 1,\par
        .command = CMD_SERVO_ON,\par
        .parameter = 0\par
    \};\par
    commands_send(&cmd1);\par
\par
    {\cf20 // Attendre la r\'E9ponse (via callback HAL_CAN_RxFifo0MsgPendingCallback)}\par
    HAL_Delay(100);\par
\par
    {\cf20 // Envoyer la commande "Servomoteur 2, position pulse 100"}\par
    command_t cmd2 = \{\par
        .device_id = 2,\par
        .command = CMD_SERVO_PULSE,\par
        .parameter = 100\par
    \};\par
    commands_send(&cmd2);\par
\par
    {\cf19 while}(1) \{\par
        {\cf20 // Boucle principale}\par
    \}\par
\}\par
}
\par
{\pard\widctlpar\brdrb\brdrs\brdrw5\brsp20 \adjustright \par}
\par}
\par}
