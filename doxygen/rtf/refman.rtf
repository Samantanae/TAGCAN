00045 \{\par
00046     {\cf17 const} TagDef* tag = get_tag_def(tag_name);\par
00047     {\cf19 if} (!tag) {\cf19 return} -3; {\cf20 // Tag non trouve}\par
00048 \par
00049     {\cf17 const} uint8_t n_bits = tag->n_bits;\par
00050     {\cf17 const} uint8_t bit_pos_a = tag->bit_pos_a;\par
00051     {\cf17 const} uint8_t bit_pos_b = tag->bit_pos_b;\par
00052     {\cf17 const} int8_t byte_idx_a = tag->byte_idx_a;\par
00053     {\cf17 const} int8_t byte_idx_b = tag->byte_idx_b;\par
00054 \par
