00065     {\cf18 size_t} total = 0;\par
00066     {\cf19 while} (total + 1 < out_size) \{\par
00067         ssize_t n = read(pipefd[0], out_buf + total, out_size - total - 1);\par
00068         {\cf19 if} (n <= 0) \{\par
00069             {\cf19 break};\par
00070         \}\par
00071         total += (size_t)n;\par
00072     \}\par
00073     close(pipefd[0]);\par
00074     out_buf[total] = {\cf23 '\\0'};\par
00075 \par
00076     {\cf19 return} ({\cf18 int})total;\par
00077 \}\par
00078 \par
00079 {\cf18 int} main__({\cf18 void})\par
00080 \{\par
00081     {\cf18 char} output[8192];\par
00082     {\cf18 int} n = capture_print_repartition_output(output, {\cf17 sizeof}(output));\par
00083     {\cf19 if} (n <= 0) \{\par
00084         fprintf(stderr, {\cf22 "[FAIL] capture output failed\\n"});\par
00085         {\cf19 return} 1;\par
00086     \}\par
00087 \par
00088     {\cf19 if} (!contains_text(output, {\cf22 "=== REPARTITION DES BITS DANS LA TRAME CAN ==="})) \{\par
00089         fprintf(stderr, {\cf22 "[FAIL] header missing\\n"});\par
00090         {\cf19 return} 1;\par
00091     \}\par
00092 \par
00093     {\cf19 if} (!contains_text(output, {\cf22 "Legende des tags:"})) \{\par
00094         fprintf(stderr, {\cf22 "[FAIL] legend title missing\\n"});\par
00095         {\cf19 return} 1;\par
00096     \}\par
00097 \par
00098     {\cf19 if} (!contains_text(output, {\cf22 "a1 : [a]"}) ||\par
00099         !contains_text(output, {\cf22 "agh5 : [b]"}) ||\par
00100         !contains_text(output, {\cf22 "patap : [c]"}) ||\par
00101         !contains_text(output, {\cf22 "patat : [d]"}) ||\par
00102         !contains_text(output, {\cf22 "uni1 : [e]"}) ||\par
00103         !contains_text(output, {\cf22 "triot : [f]"})) \{\par
00104         fprintf(stderr, {\cf22 "[FAIL] legend entries missing\\n"});\par
00105         {\cf19 return} 1;\par
00106     \}\par
00107 \par
00108     {\cf19 for} ({\cf18 int} i = 0; i < N_BYTES; i++) \{\par
00109         {\cf18 char} pattern[32];\par
00110         snprintf(pattern, {\cf17 sizeof}(pattern), {\cf22 " [%d] | "}, i);\par
00111         {\cf19 if} (!contains_text(output, pattern)) \{\par
00112             fprintf(stderr, {\cf22 "[FAIL] missing byte row: %d\\n"}, i);\par
00113             {\cf19 return} 1;\par
00114         \}\par
00115     \}\par
00116 \par
00117     printf({\cf22 "[PASS] print_repartition_bit: structure de sortie valide\\n"});\par
00118     {\cf19 return} 0;\par
00119 \}\par
