{{\pard\plain \s3\sb240\sa60\keepn\widctlpar\adjustright \b\f1\cgrid 
Code de r\'E9ception
\par}
{\tc\tcl3 \v Code de r\'E9ception}
{
\par
\pard\plain \s40\li0\widctlpar\adjustright \shading1000\cbpat8 \f2\fs16\cgrid {\cf18 void} HAL_CAN_RxFifo0MsgPendingCallback(CAN_HandleTypeDef *hcan) \{\par
    CAN_RxHeaderTypeDef RxHeader;\par
    uint8_t RxData[8];\par
\par
    {\cf20 // \'C9tape 1: Recevoir le message via HAL}\par
    {\cf19 if}(HAL_CAN_GetRxMessage(hcan, CAN_RX_FIFO0, &RxHeader, RxData) != HAL_OK) \{\par
        {\cf19 return};  {\cf20 // Erreur}\par
    \}\par
\par
    {\cf20 // \'C9tape 2a: Utiliser les donn\'E9es directement (accc\'E8s brut)}\par
    printf({\cf22 "Octet 0: 0x%02X\\n"}, RxData[0]);\par
    printf({\cf22 "Octet 1: 0x%02X\\n"}, RxData[1]);\par
\par
    {\cf20 // OU}\par
\par
    {\cf20 // \'C9tape 2b: Interpr\'E9ter via les tags}\par
    {\cf20 // (si vous avez le m\'EAme sch\'E9ma de tags c\'F4t\'E9 r\'E9cepteur)}\par
    uint32_t seq, battery;\par
    {\cf19 if}(RxData[0] & 0x38) \{  {\cf20 // Bits 3-5 contiennent possibly SEQ}\par
        {\cf20 // Extraire manuellement...}\par
    \}\par
\par
    {\cf20 // Ou utiliser les fonctions TAGCAN si vous avez copi\'E9 RxData dans TxData:}\par
    memcpy(TxData, RxData, 8);  {\cf20 // Copier RxData -> TxData}\par
    {\cf19 if}(get_value({\cf22 "SEQ"}, &seq) == CAN_TG_SUCCESS) \{\par
        printf({\cf22 "Num\'E9ro de s\'E9quence distant: %u\\n"}, seq);\par
    \}\par
\}\par
}
\par
{\pard\widctlpar\brdrb\brdrs\brdrw5\brsp20 \adjustright \par}
\par}
\par}
