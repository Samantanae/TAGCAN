00119 {\cf18 void} set_new_tag_9_to_16({\cf17 const} {\cf18 char}* tag_name, {\cf17 const} int8_t byte_idx_a, {\cf17 const} int8_t byte_idx_b, uint8_t n_bits_total)\par
