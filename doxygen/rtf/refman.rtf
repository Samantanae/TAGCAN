00078 {\cf18 void} print_repartition_bit({\cf18 void})\{\par
00079     {\cf20 // Grille de remplissage: bit_grid[byte_idx][bit_pos] = caractere du tag}\par
00080     {\cf18 char} bit_grid[N_BYTES][8];\par
00081     memset(bit_grid, {\cf23 '.'}, {\cf17 sizeof}(bit_grid));\par
00082 \par
00083     {\cf20 // Affichage de la legende}\par
00084     printf({\cf22 "=== REPARTITION DES BITS DANS LA TRAME CAN ===\\n\\n"});\par
00085     printf({\cf22 "Legende des tags:\\n"});\par
00086     {\cf18 char} possible_id[] = {\cf22 "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ"};\par
00087 \par
00088     {\cf20 // Remplir la grille avec les tags}\par
00089     {\cf19 for}({\cf18 int} i = 0; i <= g_tag_count - 1; i++)\{\par
00090         printf({\cf22 "  %s : [%c]\\n"}, g_tags[i].name, possible_id[i]);\par
00091 \par
00092         {\cf19 if}(g_tags[i].n_bits > 8)\{\par
00093             {\cf20 // Le tag s'etend sur deux bytes}\par
00094             {\cf20 // Partie A: de byte_idx_a, bits bit_pos_a a 7}\par
00095             {\cf19 for}({\cf18 int} j = g_tags[i].bit_pos_a; j < 8; j++)\{\par
00096                 bit_grid[g_tags[i].byte_idx_a][j] = possible_id[i];\par
00097             \}\par
00098             {\cf20 // Partie B: de byte_idx_b, bits 0 a (remaining_bits - 1)}\par
00099             {\cf18 int} remaining_bits = g_tags[i].n_bits - (8 - g_tags[i].bit_pos_a);\par
00100             {\cf19 for}({\cf18 int} j = 0; j < remaining_bits && j < 8; j++)\{\par
00101                 bit_grid[g_tags[i].byte_idx_b][j] = possible_id[i];\par
00102             \}\par
00103         \}\par
00104         {\cf19 else} \{\par
00105             {\cf20 // Le tag tient dans un seul byte: de bit_pos_a a (bit_pos_a + n_bits - 1)}\par
00106             {\cf19 for}({\cf18 int} j = 0; j < g_tags[i].n_bits; j++)\{\par
00107                 {\cf19 if}(g_tags[i].bit_pos_a + j < 8)\{\par
00108                     bit_grid[g_tags[i].byte_idx_a][g_tags[i].bit_pos_a + j] = possible_id[i];\par
00109                 \}\par
00110             \}\par
00111         \}\par
00112     \}\par
00113 \par
00114     {\cf20 // Affichage de la grille}\par
00115     printf({\cf22 "\\n"});\par
00116     printf({\cf22 "========================================\\n"});\par
00117     printf({\cf22 "Byte | Bit 7 6 5 4 3 2 1 0\\n"});\par
00118     printf({\cf22 "-----|---------+--------\\n"});\par
00119 \par
00120     {\cf19 for}({\cf18 int} {\cf18 byte} = 0; {\cf18 byte} < N_BYTES; {\cf18 byte}++)\{\par
00121         printf({\cf22 " [%d] | "}, {\cf18 byte});\par
00122         {\cf19 for}({\cf18 int} bit = 7; bit >= 0; bit--)\{\par
00123             printf({\cf22 "%c "}, bit_grid[{\cf18 byte}][bit]);\par
00124         \}\par
00125         printf({\cf22 "\\n"});\par
00126     \}\par
00127     printf({\cf22 "========================================\\n"});\par
00128 \}\par
