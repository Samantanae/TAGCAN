00226 {\cf20 // API publique: declaration de tag.}\par
00232 CAN_TG_STATUE set_tag({\cf17 const} {\cf18 char}* tag_name, uint8_t siz)\{\par
00233     CAN_TG_STATUE statue_actuel;\par
00234     {\cf20 // Limite du nombre de tags.}\par
00235     {\cf19 if}(g_tag_count >= MAX_TAGS)\{\par
00236         {\cf19 return} CAN_TG_ERROR_TOO_MAY_TAGS;\par
00237     \}\par
00238     {\cf20 // Validation longueur nom (implementation actuelle basee sur sizeof(pointer)).}\par
00239     {\cf19 if}({\cf17 sizeof}(tag_name) >= MAX_TAG_NAME_LEN)\{\par
00240         {\cf19 return} CAN_TG_ERROR_TAG_NAME_TO_BIGS;\par
00241     \}\par
00242     {\cf20 // Interdit les doublons de nom.}\par
00243     {\cf19 if}(get_tag_def(tag_name) != NULL)\{\par
00244         {\cf19 return} CAN_TG_ERROR_NAME_ALREADY_USE;\par
00245     \}\par
00246     {\cf20 // Nom vide invalide.}\par
00247     {\cf19 if}(tag_name[0]=={\cf23 '\\0'})\{\par
00248         {\cf19 return} CAN_TG_ERROR_TAG_NAME_INVALIDE;\par
00249     \}\par
00250     {\cf20 // Tailles acceptees: 1..16.}\par
00251     {\cf19 if}(siz <= 0 || siz > 16)\{{\cf19 return} CAN_TG_ERROR_SIZE_VALUE_INVALIDE;\}\par
00252 \par
00253     {\cf20 //------------------------- algo de placement memoire.}\par
00254 \par
00255     {\cf19 if}(siz>8)\{\par
00256         {\cf20 // Garde defensive (deja couverte plus haut).}\par
00257         {\cf19 if}(siz>16)\{\par
00258             {\cf19 return} CAN_TG_ERROR_SIZE_VALUE_INVALIDE_;\par
00259         \}\par
00260         {\cf19 else}\{\par
00261             uint8_t bytea, byteb;    {\cf20 // Index des bytes reserves.}\par
00262             statue_actuel = find_byte_with_enoung_space(siz, &bytea);\par
00263             {\cf19 if}(statue_actuel != CAN_TG_SUCCESS)\{{\cf19 return} statue_actuel;\}{\cf20 // propagation du statut}\par
00264             statue_actuel = find_byte2_with_enoung_space(siz, bytea, &byteb);\par
00265             {\cf19 if}(statue_actuel != CAN_TG_SUCCESS)\{\par
00266                 {\cf19 return} statue_actuel;   {\cf20 // propagation du statut}\par
00267             \}\par
00268             set_new_tag_9_to_16(tag_name, bytea, byteb, siz);\par
00269             {\cf19 return} CAN_TG_SUCCESS;\par
00270         \}\par
00271     \}\par
00272     {\cf19 else}\{\par
00273         uint8_t bytea;\par
00274         statue_actuel = find_byte_with_enoung_space(siz, &bytea);\par
00275         {\cf19 if}(statue_actuel != CAN_TG_SUCCESS)\{{\cf19 return} statue_actuel;\}{\cf20 // propagation du statut}\par
00276         {\cf18 int} n_tag = get_first_tags_vide();\par
00277         general_set_tag(n_tag, tag_name, siz, bytea);\par
00278         {\cf19 return} CAN_TG_SUCCESS;\par
00279     \}\par
00280 \par
00281 \par
00282 \};\par
