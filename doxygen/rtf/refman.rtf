{\bkmkstart AAAAAAAANC}
{\bkmkend AAAAAAAANC}
{{\pard\plain \s3\sb240\sa60\keepn\widctlpar\adjustright \b\f1\cgrid 
Initialisation avec filtrage
\par}
{\tc\tcl3 \v Initialisation avec filtrage}
{
\par
\pard\plain \s40\li0\widctlpar\adjustright \shading1000\cbpat8 \f2\fs16\cgrid {\cf21 #include "TAGCAN.h"}\par
{\cf21 #include "stm32f1xx_hal.h"}\par
\par
{\cf17 extern} CAN_HandleTypeDef hcan;\par
\par
{\cf18 void} init_com({\cf18 void}) \{\par
    {\cf20 // 1. Initialiser TAGCAN}\par
    CAN_init_TAGCAN();\par
    CAN_setup_TAG();\par
    CAN_setup_DF(0x123);  {\cf20 // Mon ID CAN}\par
\par
    {\cf20 // 2. Configurer les filtres}\par
    {\cf20 // Filtre 1: Accepter les messages du capteur de pression (0x200)}\par
    CAN_setup_Filter(0x200, 0x200, 0);\par
\par
    {\cf20 // Filtre 2: Accepter les messages de commande (0x100 \'E0 0x110)}\par
    CAN_setup_Filter(0x100, 0x110, 1);\par
\par
    {\cf20 // Filtre 3: Messages d'urgence (0x050)}\par
    CAN_setup_Filter(0x050, 0x050, 2);\par
\par
    {\cf20 // 3. Activer les interruptions}\par
    {\cf19 if}(HAL_CAN_ActivateNotification(&hcan, CAN_IT_RX_FIFO0_MSG_PENDING) != HAL_OK) \{\par
        Error_Handler();\par
    \}\par
\}\par
\par
{\cf18 void} HAL_CAN_RxFifo0MsgPendingCallback(CAN_HandleTypeDef *hcan) \{\par
    CAN_RxHeaderTypeDef RxHeader;\par
    uint8_t RxData[8];\par
\par
    HAL_CAN_GetRxMessage(hcan, CAN_RX_FIFO0, &RxHeader, RxData);\par
\par
    {\cf20 // Traiter selon l'ID re\'E7u}\par
    {\cf19 switch}(RxHeader.StdId) \{\par
        {\cf19 case} 0x200:\par
            handle_pressure_sensor(RxData);\par
            {\cf19 break};\par
        {\cf19 case} 0x100:\par
        {\cf19 case} 0x101:\par
        {\cf19 case} 0x102:\par
        {\cf20 // ... jusqu'\'E0 0x110}\par
            handle_command(RxData);\par
            {\cf19 break};\par
        {\cf19 case} 0x050:\par
            handle_emergency(RxData);\par
            {\cf19 break};\par
        {\cf19 default}:\par
            {\cf20 // Ne devrait jamais arriver ici gr\'E2ce aux filtres}\par
            {\cf19 break};\par
    \}\par
\}\par
}
\par
{\pard\widctlpar\brdrb\brdrs\brdrw5\brsp20 \adjustright \par}
\par}
