{{\pard\plain \s3\sb240\sa60\keepn\widctlpar\adjustright \b\f1\cgrid 
Exemples d'utilisation
\par}
{\tc\tcl3 \v Exemples d'utilisation}
{
\par
\pard\plain \s40\li0\widctlpar\adjustright \shading1000\cbpat8 \f2\fs16\cgrid {\cf20 // Dans la boucle principale ou handler}\par
{\cf17 static} {\cf18 int} seq_counter = 0;\par
\par
{\cf18 void} update_telemetry({\cf18 void}) \{\par
    {\cf20 // Incr\'E9menter et envoyer le num\'E9ro de s\'E9quence}\par
    seq_counter = (seq_counter + 1) % 8;  {\cf20 // Cycle avec 3 bits (0-7)}\par
    {\cf19 if}(set_value({\cf22 "SEQ"}, seq_counter) != CAN_TG_SUCCESS) \{\par
        {\cf20 // Erreur...}\par
    \}\par
\par
    {\cf20 // Envoyer le statut batterie}\par
    uint8_t battery_percent = read_battery();  {\cf20 // 0-100}\par
    {\cf19 if}(set_value({\cf22 "AB"}, battery_percent) != CAN_TG_SUCCESS) \{\par
        {\cf20 // Erreur...}\par
    \}\par
\par
    {\cf20 // Envoyer une pression}\par
    uint16_t pressure = read_sensor();  {\cf20 // 0-65535}\par
    {\cf19 if}(set_value({\cf22 "N2OPS"}, pressure) != CAN_TG_SUCCESS) \{\par
        {\cf20 // Erreur...}\par
    \}\par
\par
    {\cf20 // Envoyer le timestamp}\par
    uint16_t time_ms = get_timestamp();\par
    set_value({\cf22 "TIME"}, time_ms);\par
\}\par
}
\par
{\pard\widctlpar\brdrb\brdrs\brdrw5\brsp20 \adjustright \par}
\par}
