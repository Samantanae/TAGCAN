{{\pard\plain \s3\sb240\sa60\keepn\widctlpar\adjustright \b\f1\cgrid 
D\'E9marrage rapide
\par}
{\tc\tcl3 \v D\'E9marrage rapide}
{
\par
\pard\plain \s40\li0\widctlpar\adjustright \shading1000\cbpat8 \f2\fs16\cgrid {\cf20 // 1. Initialiser TAGCAN}\par
{\cf18 void} init_com({\cf18 void}) \{\par
    CAN_init_TAGCAN();      {\cf20 // Initialise le gestionnaire de tags}\par
    CAN_setup_TAG();        {\cf20 // Cr\'E9e les tags applicatifs}\par
    CAN_setup_DF(0x123);    {\cf20 // Configure le header CAN}\par
\}\par
\par
{\cf20 // 2. \'C9crire une valeur dans un tag}\par
set_value({\cf22 "SEQ"}, 5);        {\cf20 // \'C9crit 5 dans le tag "SEQ" (3 bits)}\par
\par
{\cf20 // 3. Lire une valeur depuis un tag}\par
uint32_t val;\par
get_value({\cf22 "HB"}, &val);      {\cf20 // Lit la valeur du tag "HB"}\par
\par
{\cf20 // 4. Envoyer sur le bus CAN}\par
HAL_CAN_AddTxMessage(&hcan, &TxHeader, TxData, &TxMailbox);\par
}
\par}
